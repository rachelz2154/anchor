{
  "manifest_version": 3,
  "name": "Anchor — Focus Signal",
  "version": "0.1.0",
  "description": "Sends tab activity signals to the Anchor focus agent.",
  "permissions": ["tabs", "activeTab", "alarms", "storage"],
  "host_permissions": ["http://localhost:8000/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
