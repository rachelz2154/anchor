{
  "manifest_version": 3,
  "name": "Anchor — Focus Signal",
  "version": "0.1.0",
  "description": "Sends tab activity signals to the Anchor focus agent.",
  "permissions": ["tabs", "activeTab", "alarms"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  }
}
